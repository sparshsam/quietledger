# QuietLedger — Environment Variables
# QuietLedger is a local-first PWA. No backend, no auth, no cloud sync.
# No environment variables are required for local development.
#
# Copy this file to .env and fill in your values. NEVER commit the real .env file.

# Optional: Supabase configuration for future self-hosted sync
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
